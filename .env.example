# Copy this file to `.env` and fill in real values for local development.
# In production, ops should set these as environment variables on the server.

# Basic Auth credentials required to edit projects via /manage.
# If both are empty/unset, the write API is OPEN (no auth) — useful for local dev,
# never acceptable in production.
MANAGE_USER=
MANAGE_PASS=

# Port the Express server listens on. Defaults to 3001 if unset.
# PORT=3001
